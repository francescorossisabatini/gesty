{
  "source": ["tokens.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "build/",
      "files": [
        {
          "destination": "tokens.css",
          "format": "css/variables",
          "options": { "outputReferences": true }
        }
      ]
    },
    "js": {
      "transformGroup": "js",
      "buildPath": "build/",
      "files": [
        { "destination": "tokens.js", "format": "javascript/es6" }
      ]
    },
    "json": {
      "transformGroup": "js",
      "buildPath": "build/",
      "files": [
        { "destination": "tokens.flat.json", "format": "json/flat" }
      ]
    }
  }
}
